{
  "name": "svelte",
  "version": "4.0.0",
  "description": "Cybernetically enhanced web apps",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sveltejs/svelte"
  },
  "scripts": {
    "build": "node scripts/build.js",
    "dev": "node scripts/build.js --watch",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "watch": "vitest",
    "lint": "eslint src --ext .js,.ts",
    "format": "prettier --write src",
    "prepublishOnly": "npm run build"
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./src/index.js"
    },
    "./compiler": {
      "types": "./types/compiler.d.ts",
      "import": "./src/compiler/index.js"
    },
    "./internal": {
      "types": "./types/internal.d.ts",
      "import": "./src/internal/index.js"
    },
    "./store": {
      "types": "./types/store.d.ts",
      "import": "./src/store/index.js"
    },
    "./motion": {
      "types": "./types/motion.d.ts",
      "import": "./src/motion/index.js"
    },
    "./transition": {
      "types": "./types/transition.d.ts",
      "import": "./src/transition/index.js"
    },
    "./animate": {
      "types": "./types/animate.d.ts",
      "import": "./src/animate/index.js"
    },
    "./easing": {
      "types": "./types/easing.d.ts",
      "import": "./src/easing/index.js"
    },
    "./action": {
      "types": "./types/action.d.ts"
    }
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/ui": "^0.34.0",
    "acorn": "^8.10.0",
    "acorn-typescript": "^1.4.13",
    "eslint": "^8.50.0",
    "prettier": "^3.0.0",
    "typescript": "^5.2.0",
    "vitest": "^0.34.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
